{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=TaxiApp.Backend;Trusted_Connection=True;TrustServerCertificate=True"
  },

  "JWT": {
    "Secret": "Key-Must-Be-At-Least-16-Characters-Long",
